{
  "compilerOptions": {
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDir": "./src",
    "outDir": "./dist",
    "jsx": "react",
    "esModuleInterop": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "types": ["vitest/globals", "@testing-library/jest-dom/vitest"],
    "strict": false
  },
  "include": ["test-setup.js", "vite.config.js", "src/**/*"]
}
