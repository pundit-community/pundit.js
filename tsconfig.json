{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    "outDir": "./dist",
    "baseUrl": "./src",
    "jsx": "react",
    "esModuleInterop": true,
    "strictNullChecks": true,
    "types": ["vitest/globals", "@testing-library/jest-dom/vitest"]
  },
  "include": [
    "test-setup.js",
    "vite.config.js",
    "src/**/*",
    "test/**/*",
    "examples/**/*"
  ]
}
